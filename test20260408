                if (Array.isArray(files)) {
                    console.log(`  ${field}:`, files.map(f => f.name));
                }
            });

            // 6️⃣ Hybrid 欄位
            console.log("Hybrid 欄位:");
            const scopedData = form.vm._scopedData[tabKey] || {};
            Object.entries(scopedData).forEach(([field, val]) => {
                if (!val) return;

                // 1️⃣ 排除 File 或 FileList
                const isFile = val instanceof File || val instanceof FileList;
                if (isFile) return;

                // 2️⃣ 只抓 Hybrid 格式
                if (typeof val === "object" && ("chk" in val || "txt" in val)) {
                    console.log(`  ${field}:`, val);
                }
            });

            // 7️⃣ 普通欄位 (非 Hybrid、非 File)
