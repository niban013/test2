            $("[data-df]:not([data-df-initialized])").each(function () {
                const formInstance = new DynamicFormInstance(this, window.vm);
                window.activeForm = formInstance;
                console.log("Tab 自動註冊成功:", $(this).data("df"));
            });
        }
    };

