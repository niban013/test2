        private static string RenderDropdown(DynamicField f)
        {
            var classList = new List<string> { "form-control" };
            if (f.Type == FieldType.Select2) classList.AddRange(new List<string>() { "select2-container--default", "select2" });
            if (f.Type == FieldType.Dropdown) classList.AddRange(new List<string>() { "valueInput", "dropdownColor" });
