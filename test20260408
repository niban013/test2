@using auomvc.Helper
@Html.RenderAppConfig("FileUploadConfig")

<div class="modal fade" id="uploadModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">附件上傳</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="currentStepKey">
                <input type="hidden" id="currentField">
                @* <input type="file" id="fileUpload" class="form-control mb-2" multiple> *@

                <div class="file-upload-container border p-3"
                     id="dragArea"
                     style="min-height:100px; border-style: dashed !important; background-color: #f8f9fa;">

                    <p class="text-muted mb-1">拖曳檔案到此，或點擊選擇檔案</p>

                    <!-- ⭐ 加入警語 (N 請根據你的需求修改，例如 5MB) -->
                    <p class="text-danger small mb-2" id="uploadLimitHint">
                        <i class="bi bi-exclamation-circle"></i>
                        <!-- 這裡留空，由 JS 填入 -->
                        <span class="limit-text">載入中...</span>
                    </p>

                    <input type="file" name="Resume" class="dynamicInput form-control mb-2" style="display:none;" />

                    <button type="button" class="btn btn-secondary btn-sm mb-2" id="btnSelectFile">
                        <i class="bi bi-plus-lg"></i> 選擇檔案
                    </button>

                    <hr />
                    <h6>附件清單</h6>
                    <ul class="file-list list-group mt-2" id="uploadList"></ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    $(function(){

            const $dragArea = $("#dragArea");
            const $input = $dragArea.find("input[type=file]");
            const config = window.appConfig;

            if (config) {
                const hint = `單一檔案大小上限為 ${config.MaxFileSizeMB}MB，僅支援 ${config.AllowedExtensions}等${config.FriendlyExtName}`;
                $('#uploadLimitHint .limit-text').text(hint);
            }

            // 設定 vm config（稍後上傳）
            // window.vm._fileConfig = {
            //     [tabKey]: { [field]: { uploadNow: false, uploadUrl: '/Upload/Resume' } }
            // };

            // 點擊按鈕觸發檔案選擇
            $("#btnSelectFile").click(() => $input.trigger("click"));

            // 拖曳事件
            $dragArea.on("dragover", e => { e.preventDefault(); $dragArea.addClass("drag-over"); });
            $dragArea.on("dragleave", e => { e.preventDefault(); $dragArea.removeClass("drag-over"); });
            $dragArea.on("drop", async e => {
                e.preventDefault();
                $dragArea.removeClass("drag-over");
                const files = e.originalEvent.dataTransfer.files;
                await handleFiles(files);
            });


            function syncToParentPage(stepKey, fieldPath) {
                if (window.activeForm) {
                    window.activeForm.restoreFiles();
                }
            }

            // 選檔事件
            $input.on("change", async e => await handleFiles(e.target.files));

            function appendFileToList(stepKey, fieldPath, file) {
                   const $li = $(`<li class="list-group-item d-flex flex-column align-items-start">
                                <div class="d-flex justify-content-between w-100 align-items-center">
                                    <!-- 檔名區域 -->
                                    <span class="text-truncate me-2">${file.name} (${Math.round(file.size/1024)} KB)</span>

                                    <!-- 按鈕群組：使用 d-flex 確保按鈕併排並靠右 -->
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <button type="button" class="btn btn-sm btn-outline-primary btn-preview">預覽</button>
                                        <button type="button" class="btn btn-sm btn-danger btn-delete">刪除</button>
                                    </div>
                                </div>
                                <!-- 預覽區域 -->
                                <div class="file-preview mt-2 w-100" style="display:none;"></div>
                            </li>`);

                $li.find(".btn-delete").click(function() {
                    $li.remove();
                    // ⭐ 修正：使用完整路徑刪除。這會自動觸發 PageVM 的 $watch
                    vm.removeFile(stepKey, fieldPath, file.name);

                    // 💡 既然有了 $watch，syncToParentPage 內的 restoreFiles 其實可以不用手動呼叫
                    // 但為了保險起見保留亦可
                    syncToParentPage(stepKey, fieldPath);
                });

                $li.find(".btn-preview").click(async function() {
                    const $preview = $li.find(".file-preview");

                    if ($preview.is(":visible")) {
                        $preview.slideUp(200);
                        return;
                    }

                    if ($preview.is(":empty")) {
                        let targetFile = file;
                         if (file.lazy) {
                            // 如果是從後端來的 lazy 檔案，需要先抓取實體 Blob
                            const realFiles = await vm.getFilesByField(stepKey, fieldPath);
                            // 找出檔名匹配的那一個
                            const match = realFiles.find(f => (f.name || f.filename) === file.name);
                            if (!match) { alert("無法載入檔案"); return; }
                            targetFile = match;
                        }


                        const fileUrl = URL.createObjectURL(targetFile instanceof File ? targetFile : targetFile.file);
                        const fileName = (targetFile.name || targetFile.filename).toLowerCase();
                        const fileType = targetFile.type || "";

                        if (fileType.startsWith("image/")) {
                            const img = new Image();
                            img.src = fileUrl;
                            img.className = "img-thumbnail";
                            img.style.maxWidth = "100%";
                            img.onload = function() {
                                $preview.html(img);
                                $preview.slideDown(300);
                            };
                        }
                        else if (fileType === "application/pdf") {
                            $preview.html(`<iframe src="${fileUrl}" style="width:100%; height:400px; border:1px solid #ccc;"></iframe>`);
                            $preview.show();
                        }
                        // ⭐ 新增：支援 Word 與 Excel 的處理
                        else if (fileName.match(/\.(docx|doc|xlsx|xls)$/)) {
                            let icon = fileName.includes('xls') ? 'bi-file-earmark-excel text-success' : 'bi-file-earmark-word text-primary';

                            $preview.html(`
                                <div class="alert alert-light border d-flex align-items-center m-0 p-2">
                                    <i class="bi ${icon} fs-4 me-2"></i>
                                    <span class="me-auto">此檔案不支援線上預覽</span>
                                    <a href="${fileUrl}" download="${file.name}" class="btn btn-sm btn-outline-secondary">下載查看</a>
                                </div>
                            `);
                            $preview.slideDown(300);
                        }
                        else {
                            $preview.html(`<div class="alert alert-warning py-1 m-0">此格式不支援預覽</div>`);
                            $preview.slideDown(300);
                        }
                    } else {
                        $preview.slideDown(300);
                    }
                });



                $dragArea.find(".file-list").append($li);

                //  if (window.activeForm) {
                //     // 找到主頁面對應的那個 input 或按鈕容器
                //     const $input = $(`[name="${field}"]`);
                //     // 呼叫你類別裡的 showFileNames 重新渲染表格旁邊的小清單
                //     window.activeForm.showFileNames($input, files);
                // }
            }
            // 處理檔案
            async function handleFiles(files){
                const $fileList = $dragArea.find(".file-list");
                const stepKey = $('#currentStepKey').val();
                const fieldPath = $('#currentField').val();

                const config = window.appConfig;
             
                const pattern = config.AllowedExtensions.replace(/\./g, "\\.").replace(/,/g, "|");
                const allowedExtensions = new RegExp(`(${pattern})$`, "i");

                //const allowedExtensions = /(\.jpg|\.jpeg|\.png|\.pdf|\.doc|\.docx|\.xls|\.xlsx)$/i;

                const MAX_SIZE_MB = config.MaxFileSizeMB; // 💡 設定限制大小 (例如 5MB)

                if (!stepKey || !fieldPath) return;
           
                const existingFiles = await vm.getFilesByField(stepKey, fieldPath);

                 Array.from(files).forEach(file => {
                    if (!allowedExtensions.exec(file.name)) {
                    showAlert('提示', `檔案「${file.name}」格式不符！\n 僅支援 ${config.AllowedExtensions}等${config.FriendlyExtName}`, 'warning');
                        return; // 跳過此檔案
                    }
                                        // ⭐ 檢查 1：檔案大小限制
                    const fileSizeMB = file.size / (1024 * 1024);
                    if (fileSizeMB > MAX_SIZE_MB) {
                        showAlert('提示', `檔案「${file.name}」超過 ${MAX_SIZE_MB}MB，無法上傳。`, 'warning');
                        return; // 跳過此檔案
                    }

                    const saveFileAction = (isOverwrite = false) => {
                        if (isOverwrite) {
                            // ⭐ 如果是覆寫，先從 vm 移除同名檔案
                            vm.removeFile(stepKey, fieldPath, file.name);

                            // 同時移除畫面上舊的 <li> (根據檔名尋找)
                            $fileList.find(`li:contains("${file.name}")`).remove();
                        } 
                        vm.setFile(stepKey, fieldPath, file); 
                        appendFileToList(stepKey, fieldPath, file);
                        syncToParentPage(stepKey, fieldPath);
                    };

                    // ⭐ 檢查 2：重複檔名檢查
                    // 比對現有陣列中是否有相同名稱的檔案
                    const isDuplicate = existingFiles.some(f => f.name === file.name);
                    if (isDuplicate) {
                            window.showConfirm(
                                '檔案重複',
                                `「${file.name}」已在清單中，是否覆蓋舊檔案？`,
                                // 💡 關鍵：用 () => 包起來，這才是一個「待命」的動作
                                () => {
                                    saveFileAction(true);
                                }
                            );
                                                    // window.showConfirm(
                        //     '檔案重複',
                        //     `「${file.name}」已在清單中，是否重複加入？`,
                        //      saveFileAction(true) // 💡 使用者按確定後會執行這個 function
                        // );
                    } else {
                        // 沒重複，直接執行
                        saveFileAction(false);
                    }
                });

                $input.val(''); // 清空 input 讓同檔名可重複觸發
            }

            $('#uploadModal').on('show.bs.modal', function () {
                const $fileList = $dragArea.find(".file-list");
                $fileList.empty();
                $fileList.html(''); // 雙重清空確保萬無一失
                setTimeout(async () => {
                    const stepKey = $('#currentStepKey').val();
                    const fieldPath  = $('#currentField').val();
               
                    if (!stepKey || !fieldPath) return;
                    // 從 vm 撈出該欄位現有的檔案陣列
                    try {
                        // ⭐ 修正：使用 PageVM 體系取得檔案
                        // getFilesByField 內部已修正為支援 _getNested
                        const existingFiles = await vm.getFilesByField(stepKey, fieldPath);

                        // 確保 existingFiles 是陣列再遍歷
                        if (Array.isArray(existingFiles)) {
                            existingFiles.forEach(file => {
                                // file 可能是實體 File，也可能是包含 {name, lazy: true} 的物件
                                appendFileToList(stepKey, fieldPath, file);
                            });
                        }
                    } catch (err) {
                        console.error("[UploadModal] 讀取現有檔案失敗:", err);
                    }
                }, 100);
            });
            // 統一上傳
            // $("#btnUploadAll").click(async function(){
            //     const file = vm.getFile(tabKey, field);
            //     const config = vm._fileConfig[tabKey][field];

            //     if(file && config.uploadUrl){
