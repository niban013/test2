var DynamicForm = (function () {

    class PageVM {

        constructor() {
            this.forms = [];
            this._scopedData = {};
            this._watchers = {};
            this._computed = {};
            this._computedCache = {};
            this._dirty = {};
            this._validators = {};
            this._customData = {};
            this._pagePath = window.location.pathname;
        }

        // ================= 工具 =================

        static _setNested(obj, path, value) {
            if (!obj) return;
            const keys = path.split(".");
            let t = obj;
            keys.forEach((k, i) => {
                if (i === keys.length - 1) {
                    t[k] = value;
                } else {
                    if (!t[k] || typeof t[k] !== "object") t[k] = {};
                    t = t[k];
                }
            });
        }

        static _getNested(obj, path) {
            if (!obj || !path) return undefined;
            const keys = path.split(".");
            let t = obj;
            for (let k of keys) {
                // 防禦性檢查：確保中間節點存在且不是 null
                if (t === null || t === undefined || typeof t !== "object") return undefined;
                t = t[k];
            }
            return t;
        }

        static _flatten(obj, prefix = "", res = {}) {
            const entries = Object.entries(obj || {});
            if (entries.length === 0 && prefix) {
                res[prefix] = obj; // 保留原始值(如空物件或空陣列)
                return res;
            }
            entries.forEach(([k, v]) => {
                const path = prefix ? `${prefix}.${k}` : k;
                // 排除 File, Array 與 null
                if (typeof v === "object" && v !== null && !(v instanceof File) && !Array.isArray(v)) {
                    PageVM._flatten(v, path, res);
                } else {
                    res[path] = v;
                }
            });
            return res;
        }

        // ================= register =================

        register(form) {
            this.forms = this.forms.filter(f => f.key !== form.key);
            this.forms.push(form);

            const key = form.key;
            this._scopedData[key] = this._scopedData[key] || {};
            this._dirty[key] = this._dirty[key] || new Set();
            this._watchers[key] = this._watchers[key] || {};
            this._computed[key] = this._computed[key] || {};
            this._computedCache[key] = {};

            const proxyCache = new WeakMap();

            const makeReactive = (obj, path = []) => {
                if (typeof obj !== "object" || obj === null || obj instanceof File) return obj;
                if (proxyCache.has(obj)) return proxyCache.get(obj);

                const proxy = new Proxy(obj, {
                    set: (t, k, v) => {
                        const old = t[k];
                        if (old === v) return true;

                        const fullPath = [...path, k].join(".");
                        // 賦值時，如果是物件則繼續包裝 Proxy
                        t[k] = (typeof v === "object" && v !== null) ? makeReactive(v, [...path, k]) : v;

                        this._dirty[key].add(fullPath);

                        // 觸發監聽
                        const fns = PageVM._getNested(this._watchers[key], fullPath);
                        if (Array.isArray(fns)) {
                            fns.forEach(fn => fn(t[k], old));
                        }

                        this._computedCache[key] = {};
                        return true;
                    },
                    get: (t, k) => {
                        if (path.length === 0 && this._computed[key][k]) {
                            if (this._computedCache[key][k] === undefined) {
                                this._computedCache[key][k] = this._computed[key][k].call(this[key]);
                            }
                            return this._computedCache[key][k];
                        }
                        const val = t[k];
                        return makeReactive(val, [...path, k]);
                    }
                });

                proxyCache.set(obj, proxy);
                return proxy;
            };

            // 初始化資料
            Object.entries(form.fieldCache || {}).forEach(([path, v]) => {
                PageVM._setNested(this._scopedData[key], path, v);
            });

            const rootProxy = makeReactive(this._scopedData[key]);
            form.proxy = rootProxy;
            this[key] = rootProxy;
        }

        // ================= API =================

        $watch(tabKey, path, fn) {
            if (!this._watchers[tabKey]) this._watchers[tabKey] = {};
            let handlers = PageVM._getNested(this._watchers[tabKey], path);
            if (!Array.isArray(handlers)) handlers = [];
            handlers.push(fn);
            PageVM._setNested(this._watchers[tabKey], path, handlers);
        }

        $computed(tabKey, name, fn) {
            this._computed[tabKey][name] = fn;
        }

        $dirty(tabKey) {
            return PageVM._flatten(this._scopedData[tabKey]);
        }

        $resetDirty(tabKey) {
            this._dirty[tabKey].clear();
        }

        cache() {
            this.forms.forEach(f => f.cache());
        }

        restore() {
            this.forms.forEach(f => f.restore());
        }

        async validate() {
            // 1. 各表單 UI 驗證
            const results = await Promise.all(this.forms.map(f => f.validateAll()));

            // 2. 自定義 $validator 驗證
            for (const [tabKey, rulesTree] of Object.entries(this._validators)) {
                const flatRules = PageVM._flatten(rulesTree);
                for (const [path, fns] of Object.entries(flatRules)) {
                    if (Array.isArray(fns)) {
                        const val = PageVM._getNested(this._scopedData[tabKey], path);
                        for (const fn of fns) {
                            const res = await fn(val);
                            if (res !== true) results.push(false);
                        }
                    }
                }
            }
            return results.every(r => r === true);
        }

        async getJsonString() {
            this.cache();
            const isValid = await this.validate();
            if (!isValid) return null;

            const serializeFiles = obj => {
                if (!obj) return obj;
                if (obj instanceof File) return obj.name;
                if (obj.file instanceof File) return obj.filename || obj.file.name;
                if (Array.isArray(obj)) return obj.map(serializeFiles);
                if (typeof obj === "object") {
                    const res = {};
                    Object.entries(obj).forEach(([k, v]) => res[k] = serializeFiles(v));
                    return res;
                }
                return obj;
            };

            let finalPayload = {};
            this.forms.forEach(f => {
                finalPayload[f.key] = serializeFiles(this._scopedData[f.key]);
            });
            return JSON.stringify(finalPayload, null, 4);
        }

        // ================= validator =================

        $validator(tabKey, path, fn) {
            if (!this._validators[tabKey]) this._validators[tabKey] = {};
            let handlers = PageVM._getNested(this._validators[tabKey], path);
            if (!Array.isArray(handlers)) handlers = [];
            handlers.push(fn);
            PageVM._setNested(this._validators[tabKey], path, handlers);
        }

        // ================= custom =================

        setCustom(tabKey, key, value) {
            if (!this._customData[tabKey]) this._customData[tabKey] = {};
            this._customData[tabKey][key] = value;
        }

        getCustom(tabKey, key) {
            return this._customData[tabKey]?.[key];
        }

        // ================= File =================

        setFile(tabKey, path, file) {
            // 1. 確保該 Tab 槽位存在
            this._scopedData[tabKey] = this._scopedData[tabKey] || {};

            // 2. 優先從 Proxy (this[tabKey]) 取得資料，這樣 push 才會觸發響應式
            const dataSource = this[tabKey] || this._scopedData[tabKey];

            let existing = PageVM._getNested(dataSource, path);

            // 3. 如果路徑下不是陣列，初始化為空陣列
            if (!Array.isArray(existing)) {
                PageVM._setNested(dataSource, path, []);
                existing = PageVM._getNested(dataSource, path);
            }

            // 4. ⭐ 執行 Push
            // 如果 dataSource 是 Proxy，這一步會觸發 PageVM 內部 Proxy 的 set
            // 進而觸發 $watch，讓畫面上的「檔案數量 Badge」自動更新
            existing.push(file);
        }

        removeFile(tabKey, path, identifier) {
            // 1. 優先取得 Proxy 來源，確保操作能觸發 $watch
            const dataSource = this[tabKey] || this._scopedData[tabKey];
            if (!dataSource) return;

            const files = PageVM._getNested(dataSource, path);
            if (!Array.isArray(files)) return;

            // 2. 執行刪除邏輯
            if (typeof identifier === "number") {
                // splice 會觸發 Proxy 的變動通知
                files.splice(identifier, 1);
            } else if (typeof identifier === "string") {
                // filter 會產生新陣列，必須重新 setNested 才能觸發 Proxy 的 set
                const filtered = files.filter(f => (f.name || f.filename) !== identifier);
                PageVM._setNested(dataSource, path, filtered);
            }

            // 3. 如果清空了，設定為空陣列（建議保留空陣列而非 undefined，避免 getNested 後續報錯）
            const updatedFiles = PageVM._getNested(dataSource, path);
            if (updatedFiles && updatedFiles.length === 0) {
                PageVM._setNested(dataSource, path, []);
            }
        }

        clearFiles(tabKey, path) {
            PageVM._setNested(this._scopedData[tabKey], path, undefined);
        }

        // ⭐ 取得檔案
        async getFilesByField(tabKey, fieldPath) {
            // 1. 使用 _getNested 支援路徑存取
            let file = PageVM._getNested(this._scopedData[tabKey], fieldPath);

            // 如果本地已有實體 File 物件（非 lazy），直接回傳
            if (file && (file instanceof File || (Array.isArray(file) && file[0] instanceof File))) {
                return file;
            }

            // ⭐ 後端抓檔案方法
            const fetchBackendFile = async (tabKey, path) => {
                // 如果後端 API 不支援點分隔路徑，可能需要將點轉成其他字元或編碼
                const safePath = encodeURIComponent(path);
                const res = await fetch(`/api/file/${tabKey}/${safePath}`);
                if (!res.ok) throw new Error(`Fetch failed: ${res.status}`);

                const blob = await res.blob();
                // 嘗試從 Content-Disposition 取得檔名，若無則使用路徑末端
                const fileName = path.split('.').pop() + (blob.type === "application/pdf" ? ".pdf" : ".img");

                return {
                    name: fileName,
                    type: blob.type,
                    blob: blob
                };
            };

            try {
                const backendData = await fetchBackendFile(tabKey, fieldPath);
                const newFile = new File([backendData.blob], backendData.name, { type: backendData.type });

                // 2. ⭐ 透過 Proxy 寫入，確保連動 UI (如綠色打勾圖示)
                if (this[tabKey]) {
                    PageVM._setNested(this[tabKey], fieldPath, [newFile]);
                } else {
                    PageVM._setNested(this._scopedData[tabKey], fieldPath, [newFile]);
                }

                return [newFile];
            } catch (err) {
                console.error("從後端抓檔案失敗", err);
                // 失敗時回傳目前本地有的（可能是 lazy 物件）或空陣列
                return PageVM._getNested(this._scopedData[tabKey], fieldPath) || [];
            }
        }


        getFilename(tabKey, path) {
            const f = PageVM._getNested(this._scopedData[tabKey], path);
            return f?.name || "";
        }

        async previewFile(tabKey,file,fieldPath) {

            if (file instanceof File) {

            } else if (typeof file === "string") {

                file = { name: file, lazy: true };
            }

            if (!file) return; 

            // ⭐ lazy load
            if (file?.lazy && fieldPath) {
                // 假設實體檔案存在於後端，這裡應呼叫你原有的下載/獲取 Blob 邏輯
                // 如果你的 getFilesByField 已經處理好路徑，請確保傳入的是完整 path
                const realFile = await this.getFilesByField(tabKey, fieldPath);
                if (!realFile) {
                    alert("檔案載入失敗");
                    return;
                }
                file = realFile[0].file;
            }
             
            const win = window.open("", "_blank", "width=1000,height=700");
            if (!win) {
                alert("請允許彈出視窗");
                return;
            } 
            
            const url = URL.createObjectURL(file);

            // ===== 內部專用 helper: 圖片/PDF互動 =====
            const _initPreviewInteraction = (type, targetId, sliderId, options = {}) => {
                const el = win.document.getElementById(targetId);
                const slider = win.document.getElementById(sliderId);
                if (!el || !slider) return;

                let scale = 1;
                let translateX = 0, translateY = 0;
                let isDragging = false;
                let startX, startY;

                const minScale = options.minScale || 0.5;
                const maxScale = options.maxScale || 5;
                const step = options.step || 0.01;

                const applyTransform = () => {
                    if (type === "image") {
                        el.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
                    } else if (type === "pdf") {
                        el.style.transformOrigin = "top left";
                        el.style.transform = `scale(${scale})`;
                    }
                };

                slider.min = minScale;
                slider.max = maxScale;
                slider.step = step;
                slider.value = scale;

                slider.oninput = e => {
                    scale = parseFloat(e.target.value);
                    applyTransform();
                };

                if (type === "image") {
                    el.style.cursor = "grab";
                    el.onwheel = e => {
                        e.preventDefault();
                        scale += e.deltaY * -0.001;
                        scale = Math.min(Math.max(minScale, scale), maxScale);
                        applyTransform();
                        slider.value = scale;
                    };
                    el.onmousedown = e => {
                        isDragging = true;
                        startX = e.clientX - translateX;
                        startY = e.clientY - translateY;
                        el.style.cursor = "grabbing";
                    };
                    win.document.onmouseup = () => {
                        isDragging = false;
                        el.style.cursor = "grab";
                    };
                    win.document.onmousemove = e => {
                        if (!isDragging) return;
                        translateX = e.clientX - startX;
                        translateY = e.clientY - startY;
                        applyTransform();
                    };
                }

                if (type === "pdf" && options.zoomInId && options.zoomOutId) {
                    const zoomInBtn = win.document.getElementById(options.zoomInId);
                    const zoomOutBtn = win.document.getElementById(options.zoomOutId);
                    if (zoomInBtn) zoomInBtn.onclick = () => { scale = Math.min(scale + 0.1, maxScale); applyTransform(); slider.value = scale; };
                    if (zoomOutBtn) zoomOutBtn.onclick = () => { scale = Math.max(scale - 0.1, minScale); applyTransform(); slider.value = scale; };
                }
            };

            // ===== 決定內容 =====
            let content = "";
            if (file.type.startsWith("image/")) {
                content = `
        <div style="display:flex; flex-direction:column; align-items:center; width:100%; height:100%;">
            <img id="previewImg" src="${url}" 
                 style="max-width:100%; max-height:80%; cursor:grab; transform:scale(1);" />
            <input type="range" id="imgZoom" min="0.5" max="5" step="0.01" value="1" style="width:80%; margin-top:5px;">
        </div>`;
            } else if (file.type === "application/pdf") {
                content = `
        <div style="display:flex; flex-direction:column; height:100%; width:100%;">
            <div style="display:flex; gap:5px; padding:5px; align-items:center;">
                <button id="pdfZoomIn">+</button>
                <button id="pdfZoomOut">-</button>
                <input type="range" id="pdfZoomSlider" min="0.5" max="3" step="0.01" value="1" style="flex:1;">
            </div>
            <iframe id="pdfFrame" src="${url}" style="width:100%; flex:1; border:none;"></iframe>
        </div>`;
            } else {
                // fallback: 下載
                const a = document.createElement("a");
                a.href = url;
                a.download = file.name;
                a.click();
                URL.revokeObjectURL(url);
                return;
            }

            // ===== render =====
            win.document.body.style.margin = "0";
            win.document.body.innerHTML = `
    <div style="height:100%; display:flex; flex-direction:column;">
        <div style="padding:5px; background:#f1f1f1;">${file.name}</div>
        <div id="content" style="flex:1; display:flex; justify-content:center; align-items:center;">
            ${content}
        </div>
    </div>`;

            // ===== 初始化互動 =====
            if (file.type.startsWith("image/")) {
                _initPreviewInteraction("image", "previewImg", "imgZoom");
            } else if (file.type === "application/pdf") {
                _initPreviewInteraction("pdf", "pdfFrame", "pdfZoomSlider", {
                    minScale: 0.5,
                    maxScale: 3,
                    step: 0.01,
                    zoomInId: "pdfZoomIn",
                    zoomOutId: "pdfZoomOut"
                });
            }

            // ===== 清理 ObjectURL =====
            win.addEventListener("beforeunload", () => URL.revokeObjectURL(url));
        }

        // ⭐ 處理檔案輸入（inline / modal 共用）
        async handleFileInput(tabKey, fieldPath, file, options) {
