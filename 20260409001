            // ⭐ 修正重點 1：先從 _scopedData 拿到空的原始物件並建立根代理
            const rootProxy = makeReactive(_scopedData.get(this)[key]);

            // ⭐ 修正重點 2：先掛載到 VM 實例上，確保對外引用一致
            this[key] = rootProxy;
            form.proxy = rootProxy;
           
            // ⭐ 修正重點 3：透過 rootProxy 寫入初始資料
            // 這樣 setNested 內部每一層的賦值都會經過 Proxy 的 set 攔截器
            Object.entries(form.fieldCache || {}).forEach(([p, v]) => {
