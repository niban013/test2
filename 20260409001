            const parentPath = keys.join(".");

            // 2. 找到父層 Proxy (必須透過 rootProxy 找，才會維持代理鏈)
            let target = parentPath ? getNested(rootProxy, parentPath) : rootProxy;

            if (target && typeof target === "object") {
