                        console.log('Reflect 執行結果:', success);
                        console.log('物理檢查是否還在:', target.hasOwnProperty(prop));

                        if (success) {
                            // 3. 紀錄髒數據
                            _dirty.get(this)[key].add(fullPath);

                            // 4. 觸發當前欄位更新（通知值變為 undefined）
                            trigger(key, fullPath, undefined, old, true);

                            // 5. 通知所有父層路徑
                            let parentPath = fullPath;
                            while (parentPath.includes(".")) {
                                parentPath = parentPath.substring(0, parentPath.lastIndexOf("."));

                                // 這裡直接從原始 ScopedData 拿值，避免觸發 Proxy get 導致重新封裝
                                const rawRoot = _scopedData.get(this)[key];
                                const val = _utils.get(this).getNested(rawRoot, parentPath);

                                trigger(key, parentPath, val, val, false);
                            }
                        }
                        this._isDeleting = null; 
                        return success;
                    }

