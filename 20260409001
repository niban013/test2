            if (value !== undefined) {
                const compareValue = value; // 此時 value 可能是 "" 或其他值
                const isSame = (typeof compareValue === 'object')
                    ? JSON.stringify(current) === JSON.stringify(compareValue)
                    : current === compareValue;

                if (isSame) return;
