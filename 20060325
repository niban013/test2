var DynamicForm = (function(){

    class DynamicFormInstance {
        constructor(container){
            this.container = $(container);
            this.asyncCache = {};      // async 驗證 cache
            this.fieldCache = {};      // 每個欄位的值 cache
            this.asyncTokens = {};

            // 初始資料和 proxy
            this.data = {};
            this.proxyData = new Proxy(this.data, {
                set: (target, key, value) => {
                    target[key] = value;
                    this.updateField(key, value);
                    return true;
                }
            });

            this.init();
        }

        init(){
            this.container.find(".dynamicInput").each((_,el)=>{
                const $el = $(el);
                const name = $el.attr("name");

                if(!$el.parent().hasClass("input-with-status")) $el.wrap('<div class="input-with-status"></div>');

                // 初始化 default
                let def = $el.data("default") || "";
                if(!$el.val() && def) $el.val(def);

                // cache 初始值
                this.fieldCache[name] = $el.val() || "";

                // 初始化 data
                this.proxyData[name] = $el.val() || "";

                // 初始化 Select2
                if($el.hasClass("select2")) this.initSelect2($el);

                // 清除 icon
                this.clearStatusIcon($el);
            });

            this.bindEvents();
        }

        initSelect2($el){
