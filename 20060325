            this._fileData[tabKey][field] = file;
        }

        getFile(tabKey, field) {
            return this._fileData[tabKey]?.[field];
        }

        removeFile(tabKey, field) {
            if (this._fileData[tabKey]) delete this._fileData[tabKey][field];
        }

        $dirty(tabKey) { 
            const result = {};
            this._dirty[tabKey].forEach(k => result[k] = this._scopedData[tabKey][k]);
            return result;
        }

        $resetDirty(tabKey) { this._dirty[tabKey].clear(); }
        cache() { this.forms.forEach(f => f.cache()); }
        restore() { this.forms.forEach(f => f.restore()); }
        showCache() { this.forms.forEach(f => console.log(`Cache for ${f.key}:`, f.fieldCache)); }

        async validate() {
            const results = await Promise.all(this.forms.map(f => f.validateAll()));
            return results.every(r => r);
        }
    }

    class DynamicFormInstance {
        constructor(container, vm) {
            this.container = $(container);
            this.inputs = this.container.find(".dynamicInput");
            this.vm = vm;
            this.key = this.container.data("df");
            this.fieldCache = {};
            this.data = {};
            this.proxyData = new Proxy(this.data, {
                set: (target, key, value) => {
                    target[key] = value;
                    this.updateField(key, value, false);
                    return true;
                }
            });

            this.init();
            this.vm.register(this);
        }

        init() {
            this.inputs.each((_, el) => {
                const $el = $(el);
                const name = $el.attr("name");

                if ($el.attr("type") === "file") {
                    this.initFileInput($el);
                }

                const def = $el.data("default") || "";
                if (!$el.val() && def) $el.val(def);

                this.fieldCache[name] = $el.val() || "";
                this.proxyData[name] = $el.val() || "";
                (this.vm._scopedData[this.key] ||= {})[name] = $el.val() || "";
            });

            this.bindEvents();
        }

        initFileInput($el) {
            const field = $el.attr("name");
            const tab = this.key;
            const config = this.vm._fileConfig?.[tab]?.[field] || { uploadNow: false, uploadUrl: "" };

            $el.on("change", async e => {
                const file = e.target.files[0];
                this.vm.setFile(tab, field, file);

                if (!file) return;
                const preview = $el.next(".file-preview");
                if (preview.length === 0) $el.after('<div class="file-preview mt-1"></div>');

                $el.next(".file-preview").text(file.name);

                if (config.uploadNow && config.uploadUrl) {
                    const formData = new FormData();
                    formData.append("file", file);
                    try {
                        const res = await $.ajax({
                            url: config.uploadUrl,
                            method: "POST",
                            data: formData,
                            processData: false,
                            contentType: false
                        });
                        console.log("檔案上傳成功:", res);
                    } catch (err) {
                        console.error("檔案上傳失敗", err);
                    }
                }
            });
        }

        updateField(name, value, validate = true) {
            const $el = this.inputs.filter(`[name="${name}"]`);
            if (!$el.length) return;
            if ($el.val() == value) return;
            $el.val(value);
            this.fieldCache[name] = value;
            this.proxyData[name] = value;
            (this.vm._scopedData[this.key] ||= {})[name] = value;
        }

        bindEvents() {
            this.container.on("input", ".dynamicInput", e => {
                const $el = $(e.currentTarget);
                const name = $el.attr("name");
                this.proxyData[name] = $el.val();
                this.fieldCache[name] = $el.val();
                (this.vm._scopedData[this.key] ||= {})[name] = $el.val();
            });
        }

        cache() { this.inputs.each((_, el) => this.fieldCache[$(el).attr("name")] = $(el).val()); }

        restore() {
            Object.entries(this.fieldCache).forEach(([k, v]) => {
                const $el = this.inputs.filter(`[name="${k}"]`);
                if ($el.length && $el.attr("type") !== "file") $el.val(v);
            });
        }

        async validateAll() { return true; }
    }

    function initAll(config = {}) {
        const vm = new PageVM(config);
        window.vm = vm;

        $("[data-df]").each(function () {
            const $el = $(this);
            if ($el.data("df-initialized")) return;
            const form = new DynamicFormInstance(this, vm);
            form.key = $el.data("df");
            $el.data("df-initialized", true);
            $el.data("form", form);
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", () => initAll());
    } else {
        initAll();
    }

    return {};
})();
