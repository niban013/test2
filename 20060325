using Microsoft.AspNetCore.Html;
using Microsoft.AspNetCore.Mvc.Rendering;
using System.Text;
using vsnet8.Models;

namespace vsnet8.Helpers
{
    public static class DynamicFormTypeHelper
    {
        public static IHtmlContent RenderDynamicFormTypes(
            this IHtmlHelper html,
            Dictionary<string, List<DynamicField>> model)
        {
            var sb = new StringBuilder();

            sb.AppendLine("<script>");

            // 🔹 每個 Tab 型別
            foreach (var tab in model)
            {
                var safeKey = Safe(tab.Key);

                sb.AppendLine("/**");
                sb.AppendLine($" * @typedef {{Object}} {safeKey}");

                foreach (var field in tab.Value)
                {
                    var type = MapType(field.Type);
                    var safeField = Safe(field.Name);

                    sb.AppendLine($" * @property {{{type}}} {safeField}");
                }

                sb.AppendLine(" */");
            }

            // 🔹 VM 型別
            sb.AppendLine("/**");
            sb.AppendLine(" * @typedef {Object} VMType");

            foreach (var tab in model)
            {
                var safeKey = Safe(tab.Key);
                sb.AppendLine($" * @property {{{safeKey}}} {safeKey}");
            }

            sb.AppendLine(" */");

            sb.AppendLine("</script>");

            return new HtmlString(sb.ToString());
        }

        // 🔹 型別轉換
        private static string MapType(string type)
        {
            return type switch
            {
                "int" => "number",
                "number" => "number",
                "decimal" => "number",
                "bool" => "boolean",
                "date" => "string",
                _ => "string"
            };
        }

        // 🔹 避免非法 JS 名稱
        private static string Safe(string input)
        {
            return input
                .Replace(" ", "")
                .Replace("-", "_");
        }
    }
}
