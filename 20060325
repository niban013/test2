window.DynamicFormPlugin = (function () {

    function install(vm) {

        // =========================
        // ⭐ RULE STORAGE
        // =========================
        vm._rules = {};
        vm._errors = {};

        // =========================
        // ⭐ 設定 rules
        // =========================
        vm.$rules = function (tabKey, schema) {
            this._rules[tabKey] = schema;
        };

        // =========================
        // ⭐ 取得 errors
        // =========================
        vm.$getErrors = function (tabKey) {
            return this._errors[tabKey] || {};
        };

        // =========================
        // ⭐ summary UI
        // =========================
        vm.$summary = function (tabKey, selector) {
            const $box = $(selector);

            const render = () => {
                const errs = this.$getErrors(tabKey);
                let html = Object.entries(errs)
                    .map(([k, v]) => `<div>🔸 ${k}: ${v}</div>`)
                    .join("");

                $box.html(html);
            };

            // watch dirty 觸發更新
            setInterval(render, 500);
        };

        // =========================
        // ⭐ 核心：執行 rules
        // =========================
        vm.$runRules = async function (ctx) {
            const { tabKey, field, value, el, form } = ctx;

            const rules = this._rules?.[tabKey]?.[field];
            if (!rules) return true;

            for (let r of rules) {

                // ===== required =====
                if (r.rule === "required") {
                    if (!value) return r.message || "必填";
                }

                // ===== min =====
                if (r.rule === "min") {
                    if (Number(value) < r.value) return r.message;
                }

                // ===== max =====
                if (r.rule === "max") {
                    if (Number(value) > r.value) return r.message;
                }

                // ===== requiredIf =====
                if (r.rule === "requiredIf") {
                    if (r.when(ctx) && !value) return r.message;
                }

                // ===== compare =====
                if (r.rule === "compare") {
                    let other = form.vm[tabKey][r.field];
                    if (r.op === ">" && Number(value) <= Number(other)) {
                        return r.message;
                    }
                }

                // ===== async =====
                if (r.rule === "async") {
                    let res = await r.handler(value, ctx);
                    if (res !== true) return res;
                }
            }

            return true;
        };

    }

    return { install };

})();
