稍後上傳該怎麼做

明白！「稍後上傳」就是先把檔案暫存到 vm._fileData，等到使用者按「送出」或「儲存」時再統一上傳，而不是選檔就馬上上傳。下面我整理一個完整做法：

1️⃣ 在 PageVM 記錄檔案
// 選檔時暫存
setFile(tabKey, field, file) {
    if (!this._fileData[tabKey]) this._fileData[tabKey] = {};
    this._fileData[tabKey][field] = file; // ⭐ 暫存檔案
}

getFile(tabKey, field) {
    return this._fileData[tabKey]?.[field];
}

removeFile(tabKey, field) {
    if (this._fileData[tabKey]) delete this._fileData[tabKey][field];
}
選檔就執行 setFile，不用立即呼叫上傳 API。

2️⃣ DynamicFormInstance 初始化檔案欄位
initFileInput($el) {
    const field = $el.attr("name");
    const tab = this.key;
    const config = this.vm._fileConfig?.[tab]?.[field] || { uploadNow: false, uploadUrl: "" };

    $el.on("change", e => {
        const file = e.target.files[0];
