class PageVM {
    constructor() {
        this.forms = [];

        this._data = {};
        this._watchers = {};
        this._computed = {};
        this._computedCache = {};
        this._dirty = new Set();

        // ⭐ Proxy（vm.xxx）
        this.proxy = new Proxy(this._data, {
            set: (target, key, value) => {
                const old = target[key];

                if (old === value) return true;

                target[key] = value;

                // ⭐ dirty 記錄
                this._dirty.add(key);

                // ⭐ 更新所有 form
                this.forms.forEach(f => f.updateField(key, value, false));

                // ⭐ watcher
                if (this._watchers[key]) {
                    this._watchers[key].forEach(fn => fn(value, old));
                }

                // ⭐ computed 失效
                this._computedCache = {};

                return true;
            },
            get: (target, key) => {
                // ⭐ computed
                if (this._computed[key]) {
                    if (this._computedCache[key] === undefined) {
                        this._computedCache[key] = this._computed[key].call(this.proxy);
                    }
                    return this._computedCache[key];
                }
                return target[key];
            }
        });
    }

    register(form) {
        this.forms.push(form);

        // ⭐ 把 form 初始值灌進 vm
        Object.entries(form.fieldCache).forEach(([k, v]) => {
            if (this._data[k] === undefined) {
                this._data[k] = v;
            }
        });
    }

    // ========= API =========

    $watch(key, fn) {
        if (!this._watchers[key]) this._watchers[key] = [];
        this._watchers[key].push(fn);
    }

    $computed(key, fn) {
        this._computed[key] = fn;
    }

    $dirty() {
        const result = {};
        this._dirty.forEach(k => result[k] = this._data[k]);
        return result;
    }

    $resetDirty() {
        this._dirty.clear();
    }

    cache() {
        this.forms.forEach(f => f.cache());
    }

    restore() {
        this.forms.forEach(f => f.restore());
    }

    async validate() {
        const results = await Promise.all(this.forms.map(f => f.validateAll()));
        return results.every(r => r);
    }
}
