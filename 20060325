1️⃣ 修改 Helper (DynamicFormHelper.cs)
using Microsoft.AspNetCore.Html;
using Microsoft.AspNetCore.Mvc.Rendering;
using System.Text;

namespace vsnet8.Helpers
{
    public static class DynamicFormHelper
    {
        public static IHtmlContent RenderDynamicFormTypes(this IHtmlHelper html, Dictionary<string, List<vsnet8.Models.DynamicField>> model)
        {
            var sb = new StringBuilder();
            sb.AppendLine("<script>");
            
            // 生成每個 tab 的 typedef
            foreach (var tab in model)
            {
                sb.AppendLine($"/**");
                sb.AppendLine($" * @typedef {{Object}} {tab.Key}");
                foreach (var field in tab.Value)
                {
                    string type = "string";
                    if (field.Type == "number" || field.Type == "int") type = "number";
                    if (field.Type == "date") type = "string"; // date 用 string
                    sb.AppendLine($" * @property {{{type}}} {field.Name}");
                }
                sb.AppendLine($" */");
            }

            // 生成 VMType
            sb.AppendLine("/**");
            sb.AppendLine(" * @typedef {Object} VMType");
            foreach (var tab in model)
            {
                sb.AppendLine($" * @property {{{tab.Key}}} {tab.Key}");
            }
            sb.AppendLine(" */");

            // 直接初始化 window.vm 並生成每個 tab 物件
            sb.AppendLine("window.vm = window.vm || {};");
            foreach (var tab in model)
            {
                sb.AppendLine($"window.vm['{tab.Key}'] = window.vm['{tab.Key}'] || {{}};");
            }

            sb.AppendLine("</script>");

            return new HtmlString(sb.ToString());
        }
    }
}
