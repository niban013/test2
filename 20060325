            this.inputs = this.container.find(".dynamicInput"); // 緩存 inputs
            this.asyncCache = {};
            this.fieldCache = {};
            this.asyncTokens = {};

            // 初始資料與 Proxy
            this.data = {};
            this.proxyData = new Proxy(this.data, {
                set: (target, key, value) => {
                    target[key] = value;
                    this.updateField(key, value, false); // proxy 改變 → 更新 input，但不驗證
                    return true;
                }
            });

            this.init();
        }

        init() {
            this.inputs.each((_, el) => {
                const $el = $(el);
                const name = $el.attr("name");

                // 包裝 input
                if (!$el.parent().hasClass("input-with-status")) $el.wrap('<div class="input-with-status"></div>');

                // 初始值
                const def = $el.data("default") || "";
                if (!$el.val() && def) $el.val(def);

                // 初始化 cache
                this.fieldCache[name] = $el.val() || "";

                // 初始化 proxyData
                this.proxyData[name] = $el.val() || "";

                // 初始化 Select2
                if ($el.hasClass("select2")) this.initSelect2($el);

                this.clearStatusIcon($el);
            });

            this.bindEvents();
        }

        initSelect2($el) {
            $el.select2({
                width: '100%',
                templateResult: item => item.id ? $(<div style="background:${$(item.element).data("color") || ''};padding:4px 6px;">${item.text}</div>) : item.text,
                templateSelection: item => item.text
            }).on("select2:select select2:unselect change", () => {
                this.updateSelect2Background($el);
                const name = $el.attr("name");
                this.proxyData[name] = $el.val();
                this.validateField($el);
            });
            this.updateSelect2Background($el);
        }

        updateSelect2Background($el) {
            const color = $el.find("option:selected").data("color") || "";
            $el.next(".select2-container").find(".select2-selection--single").css("background-color", color);
        }

        updateField(name, value, validate = true) {
            const $el = this.inputs.filter([name="${name}"]);
            if (!$el.length) return;

            if ($el.hasClass("select2")) {
                $el.val(value).trigger("change.select2");
            } else {
                $el.val(value);
            }

            if (validate) this.validateField($el);

            this.fieldCache[name] = value;
        }

        setStatusIcon($el, status) {
            const $w = $el.parent(".input-with-status");
            this.clearStatusIcon($el);
            const val = $el.val()?.trim() || "";
            if ($el.data("must") && val === "") return;
            const icons = {
                success: '<i class="bi bi-check-circle text-success"></i>',
                error: '<i class="bi bi-x-circle text-danger"></i>',
                processing: '<i class="bi bi-arrow-repeat rotate text-primary"></i>'
            };
            if (icons[status]) $w.append(<span class="status-icon">${icons[status]}</span>).addClass("has-icon");
        }

        clearStatusIcon($el) {
            $el.parent(".input-with-status").find(".status-icon").remove().end().removeClass("has-icon");
        }

        setError($el, msg) {
            $el.addClass("is-invalid").css("border", "1px solid red").attr("title", msg || "");
            $el.next(".select2-container").find(".select2-selection").css("border", "1px solid red");
        }

        clearError($el) {
            $el.removeClass("is-invalid").css("border", "").attr("title", "");
            $el.next(".select2-container").find(".select2-selection").css("border", "");
        }

        async validateField(el) {
            const $el = $(el), val = $el.val()?.trim() || "", must = $el.data("must"), name = $el.attr("name");
            this.clearError($el);
            this.clearStatusIcon($el);

            if (!must && val === "") return true;
            if (must && val === "") { this.setError($el, "必填"); return false; }

            let isValid = true;
            const rules = {
                pattern: $el.data("pattern"),
                minlength: $el.data("minlength"),
                maxlength: $el.data("maxlength"),
                min: $el.attr("min"),
                max: $el.attr("max"),
                conditional: $el.data("conditional"),
                cross: $el.data("cross"),
                asyncUrl: $el.data("async")
            };

            // 基本驗證
            if (rules.pattern && val && !(new RegExp(rules.pattern)).test(val)) { this.setError($el, "格式錯誤"); isValid = false; }
            if (rules.minlength && val.length < rules.minlength) { this.setError($el, 至少${rules.minlength}字); isValid = false; }
            if (rules.maxlength && val.length > rules.maxlength) { this.setError($el, 最多${rules.maxlength}字); isValid = false; }
            if (rules.min && val && parseFloat(val) < parseFloat(rules.min)) { this.setError($el, 不可小於${rules.min}); isValid = false; }
            if (rules.max && val && parseFloat(val) > parseFloat(rules.max)) { this.setError($el, 不可大於${rules.max}); isValid = false; }

            if (rules.conditional) { const c = JSON.parse(rules.conditional); if ($(c.selector).val() && val === "") { this.setError($el, "條件必填"); isValid = false; } }
            if (rules.cross) { const c = JSON.parse(rules.cross), o = $(c.selector).val(); if (c.op === ">" && val && o && parseFloat(val) <= parseFloat(o)) { this.setError($el, 必須大於${c.selector}); isValid = false; } }

            // async 驗證 + cache
            if (rules.asyncUrl && val) {
                if (this.asyncCache[val] !== undefined) {
                    this.setStatusIcon($el, this.asyncCache[val] ? 'success' : 'error');
                    if (!this.asyncCache[val]) this.setError($el, "驗證失敗");
                    this.fieldCache[name] = val;
                    this.proxyData[name] = val;
                    return this.asyncCache[val];
                }

                if (this.asyncTokens[name]) this.asyncTokens[name].abort();

                try {
                    this.setStatusIcon($el, 'processing');
                    const resp = await $.ajax({ url: rules.asyncUrl, data: { value: val } });
                    if ($el.val()?.trim() !== val) return false;

                    this.asyncCache[val] = resp.valid;
                    this.fieldCache[name] = val;
                    this.proxyData[name] = val;

                    if (!resp.valid) { this.setError($el, resp.message || "驗證失敗"); this.setStatusIcon($el, 'error'); }
                    else { this.clearError($el); this.setStatusIcon($el, 'success'); }

                    return resp.valid;
                } catch {
                    this.asyncCache[val] = false;
                    this.fieldCache[name] = val;
                    this.proxyData[name] = val;
                    this.setError($el, "異步驗證失敗");
                    this.setStatusIcon($el, 'error');
                    return false;
                } finally { this.asyncTokens[name] = null; }
            } else {
                if (val !== "") this.setStatusIcon($el, isValid ? 'success' : 'error');
                this.fieldCache[name] = val;
                this.proxyData[name] = val;
            }

            return isValid;
        }

        async validate() {
            const results = await Promise.all(this.inputs.map((_, el) => this.validateField(el)).get());
            return results.every(r => r);
        }

        getData() { return { ...this.proxyData }; }

        cache() {
            this.inputs.each((_, el) => {
                const $el = $(el), name = $el.attr("name");
                this.fieldCache[name] = $el.val();
            });
        }

        restore() {
            Object.entries(this.fieldCache).forEach(([name, value]) => this.proxyData[name] = value);
        }

        bindEvents() {
            const debounced = this.debounce(async e => await this.validateField(e.currentTarget), 500);

            this.container.on("input", ".dynamicInput", e => {
                const $el = $(e.currentTarget);
                //this.clearStatusIcon($el);
                if ($el.val()?.trim() !== "") this.setStatusIcon($el, 'processing');
                this.proxyData[$el.attr("name")] = $el.val();
            });

            this.container.on("blur change", ".dynamicInput", debounced);

            this.container.on("change", ".dropdownColor", e => {
                const $el = $(e.currentTarget);
                $el.css("background-color", $el.find("option:selected").data("color"));
            });
        }
        async validateAll() {
            const results = await Promise.all(this.inputs.map((_, el) => this.validateField($(el))).get());
            return results.every(r => r);
        }
        debounce(fn, delay = 500) {
            let timer;
            return function (...args) {
                clearTimeout(timer);
                timer = setTimeout(() => fn.apply(this, args), delay);
            };
        }
    }

    return { create: container => new DynamicFormInstance(container) };

})();

