            });
        }

        restore() {
            Object.entries(this.fieldCache).forEach(([k, v]) => {
                this.proxyData[k] = v;
            });
        }

        bindEvents() {
            const debounced = this.debounce(e => this.validateField(e.currentTarget), 500);
