                this._computedCache = {};

                return true;
            },
            get: (target, key) => {
                // ⭐ computed
                if (this._computed[key]) {
                    if (this._computedCache[key] === undefined) {
                        this._computedCache[key] = this._computed[key].call(this.proxy);
                    }
                    return this._computedCache[key];
                }
                return target[key];
            }
        });
    }

    register(form) {
        this.forms.push(form);

        // ⭐ 初始化 vm 值（只第一次）
        Object.entries(form.fieldCache).forEach(([k, v]) => {
            if (this._data[k] === undefined) {
                this._data[k] = v;
            }
        });
    }

    // ========= API =========

    $watch(key, fn) {
        if (!this._watchers[key]) this._watchers[key] = [];
        this._watchers[key].push(fn);
    }

    $computed(key, fn) {
        this._computed[key] = fn;
    }

    $dirty() {
        const result = {};
        this._dirty.forEach(k => result[k] = this._data[k]);
        return result;
    }

    $resetDirty() {
        this._dirty.clear();
    }

    cache() {
        this.forms.forEach(f => f.cache());
    }

    restore() {
        this.forms.forEach(f => f.restore());
    }

    async validate() {
        const results = await Promise.all(this.forms.map(f => f.validateAll()));
        return results.every(r => r);
    }

    showCache() {
        this.forms.forEach((f, i) => {
            console.log(`form[${i}]`, f.fieldCache);
        });
    }
}
