        //}

        debounce(fn, delay = 500) {
            let timer;
            return (...args) => { clearTimeout(timer); timer = setTimeout(() => fn(...args), delay); };
        }
    }


    return {

        init: function () {
            const currentPath = window.location.pathname;

            // 1. 檢查全域 VM 是否存在或是否換頁
            if (!window.vm || window.vm._pagePath !== currentPath) {
