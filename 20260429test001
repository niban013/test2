    {
        public static List<SelectItem> Parse(string optionstr)
        {
            var list = new List<SelectItem>();

            if (string.IsNullOrWhiteSpace(optionstr))
                return list;

            var pairs = optionstr.Split(':');

            foreach (var p in pairs)
            {
                var kv = p.Split(',');

                if (kv.Length == 2)
                {
                    list.Add(new SelectItem
                    {
                        Value = kv[1].Trim(),
                        Text = kv[0].Trim(),
                        Color = kv[1].Trim()
                    });
                }
            }

            return list;
        }
    }


