    :root {
        --active-color: #005bb7; /* 強調藍 */
        --inactive-color: #9e9e9e; /* 未選中灰 */
        --progress-bg: #e0e0e0; /* 進度條底色 */
    }

    .wizard-container {
        padding: 0;
        margin-bottom: 20px;
    }

    .wizard-ribbon {
        --step: 1; /* 預設第一步 */
        --total: 3; /* 預設總數，會被 JS 覆蓋 */
        position: relative;
        display: flex;
        width: 100%;
        gap: 2px;
        padding-bottom: 8px;
    }

    .ribbon-step {
        position: relative;
        flex: 1;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--inactive-color);
        color: white;
        font-weight: 500;
        /* 箭頭切割 */
        clip-path: polygon(0% 0%, calc(100% - 15px) 0%, 100% 50%, calc(100% - 15px) 100%, 0% 100%, 15px 50%);
        padding-left: 15px;
        transition: all 0.3s ease;
    }

        .ribbon-step:first-child {
            clip-path: polygon(0% 0%, calc(100% - 15px) 0%, 100% 50%, calc(100% - 15px) 100%, 0% 100%);
            padding-left: 0;
        }

        .ribbon-step:last-child {
            clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%, 15px 50%);
        }

        /* 🔵 當前步驟：變為藍色 */
        .ribbon-step.active {
            background: var(--active-color) !important;
        }

        /* ⚪ 已完成步驟：根據圖片是灰色，但帶有勾勾 */
        .ribbon-step.done {
            background: var(--inactive-color);
        }

