        public ColumnSchema(string field)
        {
            // 取得當前 TableSchema.Create 指定的類別
            var type = TableSchemaContext.CurrentType;

            // 轉碼：若是從 TableSchema.Create 呼叫，會自動轉為 Json ID
            Field = type != null ? ExtendTool.GetJsonName(type, field) : field;
            Title = field;
        }

        public struct Selector<T>
        {
            public ColumnSchema Column { get; }

            // 隱式轉換 A：處理字串
            public static implicit operator Selector<T>(string propertyName)
            {
                string jName = ExtendTool.GetJsonName(typeof(T), propertyName);
                return new Selector<T>(new ColumnSchema(jName, propertyName));
            }

            // 隱式轉換 B：處理 Lambda
            public static implicit operator Selector<T>(Expression<Func<T, object>> expr)
            {
                string pName = ExtendTool.GetPropertyName(expr);
                string jName = ExtendTool.GetJsonName(typeof(T), pName);
                return new Selector<T>(new ColumnSchema(jName, pName));
            }

