Helpers.leaveStep = async function ({    stepKey,    nextStep,    checkerFactory,    context = {}}) {    let result = { isSame: true };    if (checkerFactory) {        const checker = await checkerFactory(context);        result = await checker;    }    if (!result.isSame && !result.isFirstTime) {        const ok = confirm("條件已改變，是否要重新載入下一步？");        if (!ok) return { allow: false };    }    await AppController.goTo(nextStep);    if (result.forceReload) {        await AppController.load?.();    }    return { allow: true };};

✅ next() 最乾淨版本
async function next() {    const stepKey = getStepKey();    await Helpers.leaveStep({        stepKey,        nextStep: state.currentStep.value + 1,        checkerFactory: StepLeaveRegistry.get(stepKey),        context: {            pendingValue: {},            type: null        }    });}

