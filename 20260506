🧠 最簡化解法（推薦）
✅ Step 1：建立 StepLeaveRegistry
window.StepLeaveRegistry = (() => {    const rules = {};    return {        register(stepKey, fn) {            rules[stepKey] = fn;        },        get(stepKey) {            return rules[stepKey];        }    };})();

✅ Step 2：step1 註冊 checker（乾淨）
StepLeaveRegistry.register("step1", (ctx) => {    return async () => {        const store = AppBootstrap.get("FlowStore");        const oldValue = store.get("step1", "decision");        const payload = oldValue            ? {                ...(oldValue.value ?? {}),                ...(oldValue.type ? { type: oldValue.type } : {})            }            : undefined;        const mergedValue = {            ...ctx.pendingValue,            type: ctx.type        };        const isSame =            JSON.stringify(payload ?? null) ===            JSON.stringify(mergedValue ?? null);        store.safeSet("step1", "decision", {            type: ctx.type,            value: ctx.pendingValue        });        return {            isSame,            isFirstTime: payload === undefined        };    };});

✅ Step 3：next() 變成「完全通用🔥」
async function next() {    const stepKey = getStepKey();    const checkerFactory = StepLeaveRegistry.get(stepKey);    let checker = null;    if (checkerFactory) {        checker = await checkerFactory({            pendingValue: {},            type: null        });    }    await Helpers.leaveStep({        stepKey,        nextStep: state.currentStep.value + 1,        checker: () => checker    });}

