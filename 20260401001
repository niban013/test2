        private static string RenderShowFile(DynamicField f)
        {
            return $@" <div class='dynamic-file-show dynamic-file'> 
                            <!-- 中間：文字太長會自動變 ... -->
                            <span class='filename-label' id='{f.Name}' name='{f.Name}' vmodel>
