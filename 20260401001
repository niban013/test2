                    const update = async () => {

                        let val;

                        if (el.type === "file") {

                            const file = el.files?.[0];
                            if (!file) return;

                            fileCache.steps[stepKey][key] = file;

                            val = file.name; // UI only
                        }
                        else if (el.type === "checkbox") {
                            val = el.checked;
                        }
                        else if (el.type === "number") {
                            val = el.value === "" ? null : Number(el.value);
                        }
                        else {
                            val = el.value;
                        }

                        data[key] = val;

                        dirtyMap.steps[stepKey].add(key);

                        runComputed(stepKey);

                        await validateField(stepKey, key, val, el);
                    };

                    el.addEventListener("input", update);
                    el.addEventListener("change", update);
                });
            },

            updateDom(container) {

                const stepKey = getStepKey();
                const data = formData.steps[stepKey] || {};

                const els = container.querySelectorAll("[data-field]");

                els.forEach(el => {

                    const key = el.dataset.field;

                    if (!(key in data)) return;

                    if (el.type === "file") return;

                    if (el.type === "checkbox") {
                        el.checked = data[key];
                    }
                    else {
                        el.value = data[key];
                    }
                });
            },

            restore(container) {
                this.updateDom(container);
            },

            destroy(container) {

                if (!container) return;

                container.querySelectorAll("[data-field]").forEach(el => {
                    el.dataset.bound = "";
                });
            }
        };
                     const getStepModule = (key) => {

            if (!window.StepPages) return null;

            return window.StepPages[key] || null;
        };
                const waitForStepModule = async (key) => {

            for (let i = 0; i < 50; i++) {

                if (window.StepPages?.[key]) {
                    return window.StepPages[key];
                }

                await new Promise(r => setTimeout(r, 20));
            }

            return null;
        };
        // ================================
        // 🔥 STEP LOADER
        // ================================
                  const sleep = (ms) => new Promise(r => setTimeout(r, ms));

        const loadStep = async () => {

            const res = await fetch(`/Home/Step?stepIndex=${currentStep.value}`);
            const html = await res.text();

            const container = document.getElementById("step-container");

            if (!container) {
                console.error("❌ step container not found");
                return;
            }

            // =========================
            // 1. destroy old module
            // =========================
            const stepKey = getStepKey();

            if (currentPage?.destroy) {
                currentPage.destroy(container);
            }

            Bridge.destroy(container);

            // =========================
            // 2. inject html
            // =========================
            container.innerHTML = html;

        // ⭐⭐⭐ 強制執行 partial scripts ⭐⭐⭐
        const scripts = container.querySelectorAll("script");

        scripts.forEach(oldScript => {

            const newScript = document.createElement("script");

            if (oldScript.src) {
                newScript.src = oldScript.src;
                newScript.async = false;
            } else {
                newScript.textContent = oldScript.textContent;
            }

            document.body.appendChild(newScript);
            oldScript.remove();
        })
            // =========================
            // 3. wait DOM stable (CRITICAL)
            // =========================
            await sleep(0);
            await nextTick();

            // =========================
            // 4. resolve module safely
            // =========================
            // currentPage = window.StepPages?.[stepKey] ?? null;
                currentPage = await waitForStepModule(stepKey);
            if (!currentPage) {
                console.warn(`⚠️ No Step module: ${stepKey}`);
            }

            // =========================
            // 5. init module
            // =========================
            if (currentPage?.init) {
                currentPage.init(container, {
                    formData,
                    fileCache,
                    currentStep
                });
            }

            // =========================
            // 6. bind bridge AFTER module
            // =========================
            await nextTick();

            Bridge.init(container);
            Bridge.restore(container);
        };
        // ================================
        // 🔥 ACTIONS
        // ================================

        const next = async () => {
            currentStep.value++;
            await loadStep();
        };

        const prev = async () => {
            currentStep.value--;
            await loadStep();
        };

        const goToStep = async (i) => {
            if (i === currentStep.value) return;
            currentStep.value = Number(i);
            await loadStep();
        };

        const getDirtyData = () => {

            const result = {};

            Object.keys(dirtyMap.steps).forEach(stepKey => {

                result[stepKey] = {};

                dirtyMap.steps[stepKey].forEach(key => {
                    result[stepKey][key] = formData.steps[stepKey][key];
                });
            });

            return result;
        };

        const finish = async () => {

            const payload = getDirtyData();

            console.log("🚀 DIRTY ONLY:", payload);

            await fetch("/Home/Save", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });
        };

        const dumpJson = () => {
            alert(JSON.stringify(formData, null, 2));
        };

        // ================================
        // 🔥 UI
        // ================================

        const getStepClass = (step) => {
            const i = Number(step.StepIndex);
            return {
                active: i === currentStep.value,
                done: i < currentStep.value
            };
        };

        watch(currentStep, (val) => {
            const el = document.querySelector('.wizard-ribbon');
            if (el) el.style.setProperty('--step', val);
        });

        onMounted(() => {
            loadStep();
            document.querySelector('.wizard-ribbon')
                .style.setProperty('--total', steps.value.length);
        });

        return {
            steps,
            currentStep,
            next,
            prev,
            goToStep,
            finish,
            dumpJson,
            getStepClass
        };
    }
    }).mount("#app");
</script>

}






