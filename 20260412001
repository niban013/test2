async function formautocleanup() {

    const vm = createVM();
    log("=== watcher formautocleanup ===");

    let count = 0;

    const form = { key: "tab1", _unwatchList: [] };
    vm._currentForm = form;

    // ⭐ 1. 註冊 watcher
    vm.$watch("tab1", "user.age", () => count++);

    // ⭐ 檢查 watcher 是否被註冊進 form
    if (form._unwatchList.length !== 1) {
        log("❌ FAIL: watcher 沒綁到 form");
        return;
    }

    // ⭐ 2. destroy
    form._unwatchList.forEach(fn => fn());

    // ⭐ destroy 後應該清空
    if (form._unwatchList.length !== 1) {
        // 注意：這裡通常不會變（因為你沒清 array）
        // 所以這裡只是提示，不當作 fail
        log("⚠️ 注意: unwatchList 未清空（可選優化）");
    }

    // ⭐ 3. trigger
    vm.set("tab1", "user.age", 123);

    await Promise.resolve();

    // ⭐ 4. 核心驗證
    if (count === 0) {
        log("✅ PASS: watcher 已正確清除");
    } else {
        log("❌ FAIL: watcher 未清除，count = " + count);
    }
}

