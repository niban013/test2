async function runWatchSpec() {
 const vm = createVM(); // ⭐ 重建
    console.log("=== 🧪 WATCH SPEC TEST START ===");

    const wait = () => Promise.resolve();
    const results = [];

    function assert(name, actual, expected) {
        const pass = JSON.stringify(actual) === JSON.stringify(expected);
        results.push({ name, pass, actual, expected });

        console.log(
            pass ? `✅ PASS: ${name}` : `❌ FAIL: ${name}`,
            { actual, expected }
        );
    }
 
    // =========================
    // 1️⃣ 基本觸發
    // =========================
    let log1 = [];
    vm.$watch("tab1", "user.age", (v, o) => log1.push([v, o]));

    vm.set("tab1", "user.age", 30);
    await wait();

    assert("basic trigger", log1, [[30, 20]]);

    // =========================
    // 2️⃣ 去重（同 fn）
    // =========================
    let log2 = [];
    function fn(v, o) { log2.push([v, o]); }

    vm.$watch("tab1", "user.age", fn);
    vm.$watch("tab1", "user.age", fn); // duplicate

    vm.set("tab1", "user.age", 40);
    await wait();

    // 👉 只應該觸發一次
    assert("dedupe", log2.length, 1);

    // =========================
    // 3️⃣ same value 不觸發
    // =========================
    let log3 = [];
    vm.$watch("tab1", "user.age", (v,o)=>log3.push([v,o]));

    vm.set("tab1", "user.age", 40); // same
    await wait();

    assert("same value skip", log3.length, 0);

    // =========================
    // 4️⃣ once
    // =========================
    let log4 = [];
    vm.$watch("tab1", "user.age", (v,o)=>log4.push([v,o]), { once: true });

    vm.set("tab1", "user.age", 50);
    vm.set("tab1", "user.age", 60);
    await wait();

    assert("once", log4.length, 1);

    // =========================
    // 5️⃣ unwatch
    // =========================
    let log5 = [];
    const stop = vm.$watch("tab1", "user.age", (v,o)=>log5.push([v,o]));

    vm.set("tab1", "user.age", 70);
    await wait();

    stop(); // 🔥 remove

    vm.set("tab1", "user.age", 80);
    await wait();

    assert("unwatch", log5.length, 1);

    // =========================
    // 6️⃣ batch（多次 set）
    // =========================
    let log6 = [];
    vm.$watch("tab1", "user.age", (v,o)=>log6.push([v,o]));

    for (let i = 0; i < 5; i++) {
        vm.set("tab1", "user.age", i);
    }

    await wait();

    // 👉 有 queue：應該只 1 次，值 = 4
    // 👉 沒 queue：會是 5 次
    assert("batch final value", log6.at(-1), [4, 3]);

    // =========================
    // 結果總結
    // =========================
    console.log("=== 📊 RESULT SUMMARY ===");

    const passCount = results.filter(r => r.pass).length;
    const total = results.length;

    console.table(results);
    console.log(`🎯 ${passCount}/${total} PASS`);

    if (passCount !== total) {
        console.warn("⚠️ 有測試沒過，請看 FAIL 項目");
    } else {
        console.log("🚀 ALL PASS");
    }
}
