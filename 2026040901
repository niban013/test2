        restore() {
            // 1. 因為 fieldCache 是巢狀物件，不能用單層 foreach
            // 2. 最快的方式是利用 PageVM 的 flatten 工具，將物件轉回「點路徑」陣列
            const flatData = PageVM._flatten(this.fieldCache);

            Object.entries(flatData).forEach(([path, val]) => {
                // ⭐ 修正：透過 Proxy (this.vm[this.key]) 寫入，才能觸發 $watch 同步到畫面
