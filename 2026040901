            // 確保快取是最新的
            this.cache();
            // 直接回傳 fieldCache 物件（這在 JS 中就是 JSON 格式的物件）
            return this.fieldCache;
        }

        getJsonString() {
            this.cache();
            return JSON.stringify(this.fieldCache);
