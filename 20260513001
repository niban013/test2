	function resolveFieldState({
		error,
		status,
		touched,
		submitted,
		val,
		required
	}) {

		const show = touched || submitted;

		const isEmptyval =
			val === null ||
			val === undefined ||
			val === "" ||
			(Array.isArray(val) && val.length === 0) ||
			(val instanceof File && !val);

		// required
		if (show && isEmptyval && required) {

			return {
				state: "error",
				message: "必填"
			};
		}
		if (!show && !isEmptyval && isEmpty(error) && !required) {

			return {
				state: "success",
				message: ""
			};
		}
		 
		 
		// untouched empty
		if (!show && isEmptyval) { 
			return {
				state: null,
				message: ""
			};
		}

		// processing
		if (status === "processing") {

			// 空值不顯示 spinner
			if (isEmptyval) {

				return {
					state: null,
					message: ""
				};
			}

			return {
				state: "processing",
				message: ""
			};
		}

		// error
		if (status === "error") {

			return {
				state: "error",
				message: error || ""
			};
		}
		// valid
		if (show && !isEmptyval && isEmpty(error)) {

			return {
				state: "success",
				message: ""
			};
		}
		if (status === "success" && !required) { 
			return {
				state: null,
				message: ""
			};
		}
		// success
		if (status === "success") {

			return {
				state: "success",
				message: ""
			};
		}

		return {
			state: null,
			message: ""
		};
	}
	function setReadonly(stepKey, field, readonly) {
		const el =
			document.querySelector(
				`[data-field='${field}']`
			);
		//const el =
		//	getField(stepKey, field);

		if (!el)
			return;

		const type =
			(el.type || "").toLowerCase();

		if (
			el.tagName === "SELECT" ||
			type === "checkbox" ||
			type === "radio"
		) {

			el.disabled = readonly;

		} else {

			el.readOnly = readonly;
		}

		el.classList.toggle(
			"readonly",
			readonly
		);
	}
	function findField(stepKey, field) {

		return document.querySelector(
			`[data-field='${field}']`
		);
	}
	function refreshUI(stepKey, field, value) {

		const store =
			AppBootstrap.get("FlowStore");

		const el =
			findField(stepKey, field);

		if (!el)
			return;

		// =========================
		// value sync
		// =========================
		applyValue(el, value);

		// =========================
		// state sync
		// =========================
		const ui =
			resolveFieldState({

				error:
					store.getError(stepKey, field),

				status:
					store.getStatus(stepKey, field),

				touched:
					store.isTouched(stepKey, field),

				submitted:
					store.isStepSubmitted(stepKey),

				val:
					value,

				required:
					el.dataset.rule?.includes(
						"required"
					)
			});

		if (!ui.state) {

			FieldStatus.clear(el);

			return;
		}

		FieldStatus.set(
			el,
			ui.state,
			ui.message
		);
	}
	function applyValue(el, value) { 
		const adapter = FieldAdapters.resolve(el);

		adapter.setValue(el, value);
	}
	function unbindAll(container) {

		container
			.querySelectorAll("[data-field]")
			.forEach(el => {

				const adapter =
					FieldAdapters.resolve(el);

				adapter.destroy(el);

				delete el.dataset.bound;
			});
	}
