	async function handleSSAAFUpload(
		val,
		container,
		stepKey
	) {
		const formData = new FormData();

		formData.append("file", val);

		$.ajax({
			url: '/Supplier/UploadSSAAF', // 你的路徑
			type: 'POST',
			data: formData,
			processData: false,
			contentType: false,
			success: function (response) {
				console.log("收到後端資料：", response);
				for (let mapkey in response) {
					container
						.querySelectorAll("input[data-field], select[data-field], textarea[data-field]")
						.forEach(el => {
							const key = getKey(el)
							if (mapkey == key) {

								if (el.type === "checkbox") {
									el.checked = response[key];

								} else if (el.type === "radio") {
									el.checked = (el.value === response[key]);
								}
								else {
									el.value = response[key];
								}
								GraphV2.notify(stepKey, key, isEmpty(response[key]) ? "" : response[key]);
								store.setTouched(stepKey, key);
							}
						});

					//console.log("欄位：" + key + "，值：" + response[key]);
				}
			},
			error: function (xhr, status, error) {
				console.error("出錯了：", error);
				alert("上傳或讀取失敗");
			}
		}); 
	   
