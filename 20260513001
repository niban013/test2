		// 3. 寫入 Store
		//if (store.setFieldOptions) {
		//	store.setFieldOptions(stepKey, field, formattedOptions);
		//} else {
		//	// 如果 Store 沒有專屬方法，通常是存入一個約定好的 metadata 欄位
		//	store.safeSet(stepKey, `_options_${field}`, formattedOptions);
		//}

		//// 4. (選用) 如果是純 JS 操控 DOM，這裡要直接操作 Select 元件
		//const selectEl = document.querySelector(`[data-step="${stepKey}"][name="${field}"]`);
		//if (selectEl && selectEl.tagName === 'SELECT') {
		//	selectEl.innerHTML = formattedOptions
		//		.map(opt => `<option value="${opt.value}">${opt.text}</option>`)
		//		.join('');
		//}
	}
	return { bindFields, setReadonly, setOptions, refreshUI, unbindAll };

})();

window.FieldStatus = (() => {

	const icons = {
		success: '<i class="bi bi-check-circle text-success"></i>',
		error: '<i class="bi bi-x-circle text-danger"></i>',
		processing: '<i class="bi bi-arrow-repeat rotate text-primary"></i>'
	};

	return {

		set(el, state, msg = "") {

			const field = el.closest(".field");
			if (!field) return;

			const icon = field.querySelector(".field-icon");
			const msgEl = field.querySelector(".field-msg");

			if (msgEl) msgEl.textContent = msg || "";

			el.classList.remove("is-valid", "is-invalid");

			if (!state) {
				field.classList.remove("has-icon");
				if (icon) icon.innerHTML = "";
