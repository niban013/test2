//获取浏览器URL中存储的CAP AuthToken
function CAP_GetAuthToken(cap_cookie_Name) {
    var arr, reg = new RegExp("(^| )" + cap_cookie_Name + "=([^;]*)(;|$)");
    if (arr = document.cookie.match(reg)) {
        return unescape(arr[2]);
    }
    else {
        return null;
    }
}

// 获取浏览器Cookie中存储的CAP AuthToken(推荐此方法)
function CAP_GetAuthToken (cap_cookie_Name) {
    //读取Cookie
    if (document.cookie.length > 0) {
        c_start = document.cookie.indexOf(cap_cookie_Name + "=")
        if (c_start != -1) {
            c_start = c_start + cap_cookie_Name.length + 1
            c_end = document.cookie.indexOf(";", c_start)
            if (c_end == -1) c_end = document.cookie.length
            return unescape(document.cookie.substring(c_start, c_end))
        }
    }
    return null
}

