                        file.error = null;
                        file.progress = 0;

                        PreviewModule.refreshList(stepKey, key, files);
                        //const ctx = {
                        //    stepKey,
                        //    key
                        //};
                        await controller.uploadSingleFile(
                            ctx,
                            key,
                            file,
                            files
                        );

                        return;
                    }

                    // =========================
                    // NORMAL → PREVIEW
                    // =========================
                    setPreviewLayout(true);

                    await PreviewService.open(stepKey, key, file);
                });
                $name
                .off("click")
