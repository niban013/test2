window.ValidationRules = {

	required: (val) => {

		if (val instanceof File)
			return val ? true : "必填";

		if (Array.isArray(val))
			return val.length > 0 || "必填";

		return (val === null || val === undefined || val === "")
			? "必填"
			: true;
	},

	min: (val, ctx) => {
		if (val == null || val === "") return true;
		return parseFloat(val) >= parseFloat(ctx.arg) || `不可小於${ctx.arg}`;
	},

	max: (val, ctx) => {
		if (val == null || val === "") return true;
		return parseFloat(val) <= parseFloat(ctx.arg) || `不可大於${ctx.arg}`;
	},

	// =========================
	// ⭐ NEW: file validators
	// =========================
	accept: (file, ctx) => {
		if (!file) return true;

		const types = ctx.arg.split(",");
		return types.some(t => file.type.includes(t))
			|| `檔案格式需為 ${ctx.arg}`;
	},

	maxsize: (file, ctx) => {
		if (!file) return true;

		const maxMB = parseFloat(ctx.arg);
		return file.size <= maxMB * 1024 * 1024
			|| `檔案不可超過 ${maxMB}MB`;
	},
	// =========================
	// 🔥 async validator（統一版本）
	// =========================
	// =========================
	// 🔥 async validator（升級版）
	// =========================
	async: async (val, ctx) => {

		if (val === undefined) return;

		let res;

		// =========================
		// ⭐ FILE MODE
		// =========================
		if (val instanceof File) {

			const formData = new FormData();
			formData.append("file", val);

			res = await fetch(ctx.url, {
				method: "POST",
				body: formData,
				signal: ctx.signal
			});

		}
		// =========================
		// ⭐ MULTIPLE FILE
		// =========================
		else if (Array.isArray(val) && val[0] instanceof File) {

			const formData = new FormData();

			val.forEach((f, i) => {
				formData.append(`files[${i}]`, f);
			});

			res = await fetch(ctx.url, {
				method: "POST",
				body: formData,
				signal: ctx.signal
			});
		}
		// =========================
		// ⭐ NORMAL VALUE（原本邏輯）
		// =========================
		else {

			res = await fetch(ctx.url, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					value: val,
					stepKey: ctx.stepKey,
					field: ctx.field,
					fields: ctx.fields,
					data: ctx.data
				}),
				signal: ctx.signal
			});
		}

		const data = await res.json();

		if (data.valid === false) {
			return data.message || "驗證失敗";
		}

		return {
			valid: true,
			data: data.data || {},
			message: data.message || ""
		};
	}
};

window.FieldAdapters = (() => {

	function triggerSelect2(el) {

		if (
			window.jQuery &&
			jQuery(el).data("select2")
		) {
			jQuery(el).trigger("change");
		}
	}

	// =========================
	// helpers
	// =========================
	function same(el, value) {

		return el.value === String(value ?? "");
	}

	function safeSet(el, next) {

		if (same(el, next)) return;

		el.value = next;
	}

	function defaultFocus(el) {
		el.focus();
	}

	function defaultValidate() {
		return true;
	}

	function defaultDestroy(el) {

		const $el =
			window.jQuery
				? jQuery(el)
				: null;

		// =========================
		// select2
		// =========================
		if ($el?.data("select2")) {

			$el.off(".fieldbinder");

			$el.select2("destroy");

			// 🔥 強制清 DOM（Select2 bug 必備）
			$el.removeData("select2");

			// 有些版本需要
			$el.next(".select2-container").remove();
		}
		else {

			// =========================
			// native event
			// =========================
			if (el.__handler) {

				el.removeEventListener(
					el.__eventType || "input",
					el.__handler
				);
			}
		}

		// =========================
		// blur
		// =========================
		if (el.__blurHandler) {

			el.removeEventListener(
				"blur",
				el.__blurHandler
			);
		}

		// =========================
		// cleanup
		// =========================
		delete el.__handler;
		delete el.__blurHandler;
		delete el.__eventType;
	}

	function defaultDisable(el, disabled) {

		if (
			el.tagName === "SELECT" ||
			el.type === "checkbox" ||
			el.type === "radio"
		) {
			el.disabled = disabled;
		}
		else {
			el.readOnly = disabled;
		}

		el.classList.toggle(
			"readonly",
			disabled
		);
	}

	function defaultClear(el) {

		if ("value" in el) el.value = "";

		if ("checked" in el) el.checked = false;
	}

	// =========================
	// adapters
	// =========================
	function createInputAdapter({

		getValue,
		setValue,

		event = "input",

		clear,

		focus = defaultFocus,
		disable = defaultDisable,
		validate = defaultValidate,
		destroy = defaultDestroy
	}) {

		return {

			getValue,

			setValue,

			bind(el, update) {

				el.__handler = update;
				el.__eventType = event;

				el.addEventListener(
					event,
					update
				);
			},

			clear,

			focus,
			disable,
			validate,
			destroy
		};
	}

	const adapters = {

		// =========================
		// text
		// =========================
		text: createInputAdapter({

			getValue: el => el.value,

			setValue(el, value) {

				safeSet(
					el,
					value == null
						? ""
						: String(value)
				);
			},

			clear(el) {
				el.value = "";
			}
		}),

		// =========================
		// number
		// =========================
		number: createInputAdapter({

			getValue(el) {

				return el.value === ""
					? null
					: Number(el.value);
			},

			setValue(el, value) {

				safeSet(
					el,
					value == null
						? ""
						: String(value)
				);
			},

			clear(el) {
				el.value = "";
			}
		}),

		// =========================
		// checkbox
		// =========================
		checkbox: createInputAdapter({

			event: "change",

			getValue: el => el.checked,

			setValue(el, value) {

				const checked = !!value;

				if (el.checked === checked)
					return;

				el.checked = checked;
			},

			clear(el) {
				el.checked = false;
			}
		}),

		// =========================
		// radio
		// =========================
		radio: createInputAdapter({

			event: "change",

			getValue(el, container) {

				const field =
					el.dataset.field;

				const col =
					el.dataset.col;

				const selector = col
					? `input[data-field='${field}'][data-col='${col}']:checked`
					: `input[data-field='${field}']:checked`;

				const checked =
					container.querySelector(selector);

				return checked
					? checked.value
					: null;
			},

			setValue(el, value) {

				const checked =
					String(el.value) ===
					String(value);

				if (el.checked === checked)
					return;

				el.checked = checked;
			},

			clear(el) {
				el.checked = false;
			}
		}),

		// =========================
		// file
		// =========================
		file: {

			getValue(el) {

				return el.multiple
					? Array.from(el.files || [])
					: el.files?.[0] || null;
			},

			setValue(el, value) {

				const wrapper =
					el.closest(".file-wrapper");

				if (!wrapper)
					return;

				const nameEl =
					wrapper.querySelector(".file-name");

				const actionsEl =
					wrapper.querySelector(".file-actions");

				const lineEl =
					wrapper.querySelector(".file-line");

				if (!nameEl)
					return;

				let nextText = "";

				// =========================
				// single file
				// =========================
				if (value instanceof File) {

					nextText = value.name;
				}

				// =========================
				// multi file
				// =========================
				else if (Array.isArray(value)) {

					nextText = value.length
						? value.map(f =>
							f instanceof File
								? f.name
								: String(f)
						).join(", ")
						: "";
				}

				// =========================
				// ⭐ DB filename
				// aa.xls
				// =========================
				else if (typeof value === "string") {

					nextText = value;
				}

				// =========================
				// same skip
				// =========================
				if (nameEl.textContent === nextText)
					return;

				// =========================
				// UI
				// =========================
				nameEl.textContent = nextText;

				lineEl.dataset.title = nextText || "";

				nameEl.classList.toggle(
					"d-none",
					!nextText
				);

				actionsEl?.classList.toggle(
					"d-none",
					!nextText
				);
			},

			bind(el, update) {

				el.__handler = update;
				el.__eventType = "change";

				el.addEventListener(
					"change",
					update
				);
			},

			clear(el) {

				el.value = "";

				const wrapper =
					el.closest(".file-wrapper");

				if (!wrapper)
					return;

				const nameEl =
					wrapper.querySelector(
						".file-name"
					);

				if (nameEl) {

					nameEl.textContent = "";

					nameEl.classList.add("d-none");
				}

				const actionsEl =
					wrapper.querySelector(".file-actions");

				actionsEl?.classList.add("d-none");
			},

			focus: defaultFocus,

			disable: defaultDisable,

			validate: defaultValidate,

			destroy: defaultDestroy
		},

		// =========================
		// select
		// =========================
		select: {

			getValue(el) {

				if (
					el.classList.contains(
						"dropdownColor"
					)
				) {

					const color =
						el.selectedOptions[0]
							?.dataset.color;

					el.style.backgroundColor =
						color || "";
				}

				return el.value;
			},

			setValue(el, value) {

				const next =
					value == null
						? ""
						: String(value);

				if (el.value === next)
					return;

				el.value = next;

				if (
					el.classList.contains(
						"dropdownColor"
					)
				) {

					const color =
						el.selectedOptions[0]
							?.dataset.color;

					el.style.backgroundColor =
						color || "";
				}

				triggerSelect2(el);
			},

			bind(el, update) {

				const $el = $(el);

				// =========================
				// select2
				// =========================
				if ($el.data("select2")) {

					const handler =
						() => update({ target: el });

					el.__handler = handler;

					$el.on(
						"select2:select.fieldbinder " +
						"select2:clear.fieldbinder " +
						"change.fieldbinder",
						handler
					);

					return;
				}

				// =========================
				// native select
				// =========================
				el.__handler = update;
				el.__eventType = "change";

				el.addEventListener(
					"change",
					update
				);
			},

			clear(el) {

				el.value = "";

				triggerSelect2(el);
			},

			focus: defaultFocus,

			disable(el, disabled) {

				el.disabled = disabled;

				triggerSelect2(el);
			},

			validate: defaultValidate,

			destroy: defaultDestroy
		}
	};

	// =========================
	// resolver
	// =========================
	function resolve(el) {

		if (el.type === "checkbox") return adapters.checkbox;
		if (el.type === "radio") return adapters.radio;
		if (el.type === "file") return adapters.file;
		if (el.type === "number") return adapters.number;
		if (el.tagName === "SELECT") return adapters.select;

		return adapters.text;
	}

	return {
		resolve
	};

})();

